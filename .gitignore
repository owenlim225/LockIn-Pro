# =============================================================================
# LockIn Pro – .gitignore
# Covers: docs/skills repo + planned Next.js/Node/Python tooling
# =============================================================================

# -----------------------------------------------------------------------------
# OS & editor
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.suo
*.user
*.userosscache
*.sln.docstates

# -----------------------------------------------------------------------------
# IDE / editor (uncomment if you don’t want to commit shared config)
# -----------------------------------------------------------------------------
# .idea/
# .vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Node / Next.js (when app is added)
# -----------------------------------------------------------------------------
node_modules/
.npm
.yarn/
.pnpm-store/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
.nx/cache

# -----------------------------------------------------------------------------
# Env & secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Vercel / hosting
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Python (blueprintkit scripts / future backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg

# -----------------------------------------------------------------------------
# Logs & cache
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
.temp/
tmp/
temp/
