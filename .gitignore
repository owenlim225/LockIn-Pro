# =============================================================================
# LockIn Pro – .gitignore
# Next.js 16, PWA (Serwist), Node/bun/npm/pnpm; docs/skills; optional Python
# =============================================================================

# -----------------------------------------------------------------------------
# v0 runtime files
# -----------------------------------------------------------------------------
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# -----------------------------------------------------------------------------
# OS & editor
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.suo
*.user
*.userosscache
*.sln.docstates

# -----------------------------------------------------------------------------
# IDE / editor (uncomment if you don’t want to commit shared config)
# -----------------------------------------------------------------------------
# .idea/
# .vscode/
.cursor/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Serwist PWA (generated service worker)
# -----------------------------------------------------------------------------
public/sw.js
public/sw.js.map
public/swe-worker-*
public/workbox-*
public/serialized-*

# -----------------------------------------------------------------------------
# Node / Next.js
# -----------------------------------------------------------------------------
node_modules/
.npm
.yarn/
.pnpm-store/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
.nx/cache

# -----------------------------------------------------------------------------
# Env & secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
.env*.local
!.env.example
!.env.sample
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Vercel / hosting
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Python (blueprintkit scripts / future backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg

# -----------------------------------------------------------------------------
# Logs & cache
# -----------------------------------------------------------------------------
*.log
debug-*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
.temp/
tmp/
temp/
